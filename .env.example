# Supabase — from Supabase project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Gmail SMTP (App Password from myaccount.google.com/apppasswords)
GMAIL_ADDRESS=tasklyapp.ai@gmail.com
GMAIL_APP_PASSWORD=mcnuwsfdxzjqepmp
GMAIL_FROM_NAME=Nishant Raj

# App login — pick any password you want to use for the web UI
APP_PASSWORD=change-me

# Session cookie secret — any 32+ char random string
# Generate: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-32-plus-char-string

# Cron auth — any random string; Vercel Cron auto-sends this
CRON_SECRET=change-me-to-another-random-string

# Timezone for the send window (default Asia/Kolkata)
TZ=Asia/Kolkata

# Public URL — used for tracking pixels, click-tracked links, and unsubscribe URLs.
# Set to your deployed URL in production (https://yourapp.vercel.app).
APP_URL=http://localhost:3000
